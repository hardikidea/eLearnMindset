{{!
@template mod_interactivevideo/managedefaults

Lists the saved interaction-type defaults for a course, each with a delete action.

Example context (json):
{
    "hasdefaults": true,
    "defaults": [
        {"type": "richtext", "icon": "bi bi-file-earmark-richtext", "title": "Rich text"}
    ]
}
}}
{{#hasdefaults}}
<table class="table table-striped w-100">
    <thead>
        <tr>
            <th>{{#str}}type, mod_interactivevideo{{/str}}</th>
            <th class="text-right"></th>
        </tr>
    </thead>
    <tbody>
        {{#defaults}}
        <tr data-type="{{type}}">
            <td><i class="{{icon}} mr-2"></i>{{title}}</td>
            <td class="text-right">
                <button type="button"
                        class="btn btn-sm btn-outline-danger"
                        data-action="delete-default"
                        data-type="{{type}}"
                        title="{{#str}}delete, core{{/str}}">
                    <i class="bi bi-trash3"></i>
                </button>
            </td>
        </tr>
        {{/defaults}}
    </tbody>
</table>
{{/hasdefaults}}
{{^hasdefaults}}
<div class="alert alert-info">{{#str}}nodefaultssaved, mod_interactivevideo{{/str}}</div>
{{/hasdefaults}}
