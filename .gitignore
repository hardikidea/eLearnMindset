# Local secrets and environment.
.env
.env.*
!.env.example
*.local
*.secret
*.pem
*.key
*.crt
.envrc
.direnv/

# Operating system and editor files.
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~
*.bak
*.orig
*.rej

# Logs, reports, and temporary output.
*.log
logs/
tmp/
temp/
.cache/
coverage/
reports/
.phpunit.result.cache
.phpunit.cache/
.eslintcache
.stylelintcache

# Runtime data and local backups.
backups/
moodledata/
postgres-data/
redis-data/
db-data/
plugins/

# Terraform local state and generated working directories.
**/.terraform/
.terraform/
*.tfstate
*.tfstate.*
*.tfplan
.terraform.tfstate.lock.info
crash.log
crash.*.log
*.tfvars
!*.tfvars.example
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Dependency and build output directories.
node_modules/
vendor/
dist/
build/

# Upstream Moodle source is bootstrapped from the official Moodle Git tag.
# Track only project-owned Moodle customizations below.
/moodle/*
/moodle/.git/
/moodle/.git
/moodle/.git-*/
/moodle/.git-*

!/moodle/demo-data/
!/moodle/demo-data/**

!/moodle/scripts/
/moodle/scripts/*
!/moodle/scripts/seed_indian_school_demo.php

!/moodle/public/
/moodle/public/*

!/moodle/public/admin/
/moodle/public/admin/*
!/moodle/public/admin/tool/
/moodle/public/admin/tool/*
!/moodle/public/admin/tool/courserating/
!/moodle/public/admin/tool/courserating/**

!/moodle/public/blocks/
/moodle/public/blocks/*
!/moodle/public/blocks/dash/
!/moodle/public/blocks/dash/**
!/moodle/public/blocks/whatsapp_messenger/
!/moodle/public/blocks/whatsapp_messenger/**

!/moodle/public/course/
/moodle/public/course/*
!/moodle/public/course/format/
/moodle/public/course/format/*
!/moodle/public/course/format/designer/
!/moodle/public/course/format/designer/**
!/moodle/public/course/format/remuiformat/
!/moodle/public/course/format/remuiformat/**

!/moodle/public/mod/
/moodle/public/mod/*
!/moodle/public/mod/hvp/
!/moodle/public/mod/hvp/**
!/moodle/public/mod/interactivevideo/
!/moodle/public/mod/interactivevideo/**

!/moodle/public/theme/
/moodle/public/theme/*
!/moodle/public/theme/almondb/
!/moodle/public/theme/almondb/**
!/moodle/public/theme/wideboost/
!/moodle/public/theme/wideboost/**

# Ignore nested dependency/build output inside tracked Moodle customizations.
/moodle/public/**/node_modules/
/moodle/public/**/vendor/
/moodle/public/**/dist/
/moodle/public/**/build/
/moodle/public/**/*.map
/moodle/public/**/.phpunit.cache/
/moodle/public/**/.eslintcache
