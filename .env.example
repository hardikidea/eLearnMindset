# Local Docker project name.
COMPOSE_PROJECT_NAME=elearn_mindset

# Official Moodle Git tag to check out.
# Confirm newer tags with: git ls-remote --tags --refs https://github.com/moodle/moodle.git 'v5.2*'
MOODLE_VERSION=v5.2.1

# Local web URL. Keep this in sync with MOODLE_HTTP_PORT.
MOODLE_HTTP_PORT=8080
MOODLE_WWWROOT=http://localhost:8080

# Moodle paths inside the container.
MOODLE_DIR=/var/www/moodle
MOODLE_DATAROOT=/var/www/moodledata

# Moodle database settings.
MOODLE_DB_TYPE=pgsql
MOODLE_DB_HOST=db
MOODLE_DB_PORT=5432
MOODLE_DB_PREFIX=mdl_

# PostgreSQL settings.
POSTGRES_DB=moodle
POSTGRES_USER=moodle
POSTGRES_PASSWORD=moodle_dev_password
POSTGRES_PORT=5440

# Local MailPit SMTP catcher.
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025
MOODLE_SMTP_HOSTS=mailpit:1025
MOODLE_NOREPLY_ADDRESS=noreply@example.local

# First local administrator account used by scripts/install-site.sh.
# Change these before any shared or production-like deployment.
MOODLE_ADMIN_USER=admin
MOODLE_ADMIN_PASSWORD=Admin123!ChangeMe
MOODLE_ADMIN_EMAIL=admin@example.local
MOODLE_SITE_FULLNAME="eLearn Mindset Local"
MOODLE_SITE_SHORTNAME=elearnmindset

# Runtime settings.
TZ=Asia/Kolkata
MOODLE_CRON_INTERVAL=60
MOODLE_COMPOSER_INSTALL=true
MOODLE_REVERSEPROXY=false
