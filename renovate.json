{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    ":dependencyDashboard",
    ":semanticCommits",
    ":semanticCommitTypeAll(chore)"
  ],
  "timezone": "Asia/Kolkata",
  "schedule": ["before 6am every weekday"],
  "labels": ["dependencies"],
  "prHourlyLimit": 4,
  "prConcurrentLimit": 10,
  "minimumReleaseAge": "3 days",
  "rangeStrategy": "bump",
  "rebaseWhen": "conflicted",
  "enabledManagers": [
    "custom.regex",
    "docker-compose",
    "dockerfile",
    "github-actions",
    "terraform"
  ],
  "ignorePaths": [
    "backups/**",
    "moodle/**",
    "moodledata/**",
    "**/.terraform/**"
  ],
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "Renovate Dependency Dashboard",
  "dependencyDashboardOSVVulnerabilitySummary": "all",
  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "labels": ["security", "dependencies"],
    "vulnerabilityFixStrategy": "lowest"
  },
  "major": {
    "dependencyDashboardApproval": true
  },
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions",
      "labels": ["ci", "dependencies"]
    },
    {
      "matchManagers": ["docker-compose", "dockerfile"],
      "groupName": "Docker images",
      "labels": ["docker", "dependencies"]
    },
    {
      "matchManagers": ["terraform"],
      "groupName": "Terraform providers and modules",
      "labels": ["terraform", "dependencies"]
    },
    {
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)\\.env\\.example$/",
        "/(^|/)\\.github/workflows/.*\\.ya?ml$/",
        "/(^|/)docker/moodle/Dockerfile$/"
      ],
      "matchStrings": [
        "MOODLE_VERSION\\s*[:=]\\s*[\"']?(?<currentValue>v?\\d+\\.\\d+\\.\\d+)[\"']?"
      ],
      "depNameTemplate": "moodle/moodle",
      "datasourceTemplate": "github-tags"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)docker/moodle/Dockerfile$/"],
      "matchStrings": ["ARG PHPREDIS_VERSION=(?<currentValue>\\S+)"],
      "depNameTemplate": "phpredis/phpredis",
      "datasourceTemplate": "github-tags"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)\\.github/workflows/.*\\.ya?ml$/"],
      "matchStrings": [
        "TRIVY_VERSION:\\s*(?<currentValue>v?\\d+\\.\\d+\\.\\d+)"
      ],
      "depNameTemplate": "aquasecurity/trivy",
      "datasourceTemplate": "github-tags"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["/(^|/)\\.github/workflows/.*\\.ya?ml$/"],
      "matchStrings": [
        "RENOVATE_CLI_VERSION:\\s*(?<currentValue>\\d+\\.\\d+\\.\\d+)"
      ],
      "depNameTemplate": "renovate",
      "datasourceTemplate": "npm"
    }
  ]
}
